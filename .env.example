# ============================================
# TalentSeed 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填入你的 API 密钥
# Copy this file to .env.local and fill in your API key

# --------------------------------------------
# OpenAI API 配置 (必需)
# --------------------------------------------
# 你的 OpenAI API 密钥
# Your OpenAI API key
OPENAI_API_KEY=your_api_key_here

# API 基础 URL (可选，默认为 LongCat API)
# API base URL (optional, defaults to LongCat API)
OPENAI_BASE_URL=https://api.longcat.chat/openai

# 模型名称 (可选，默认为 LongCat-Flash-Chat)
# Model name (optional, defaults to LongCat-Flash-Chat)
OPENAI_MODEL=LongCat-Flash-Chat

# --------------------------------------------
# 使用示例
# --------------------------------------------
# 方案1: 使用 LongCat API
# OPENAI_API_KEY=ak_xxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.longcat.chat/openai
# OPENAI_MODEL=LongCat-Flash-Chat

# 方案2: 使用 OpenAI 官方 API
# OPENAI_API_KEY=sk-xxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# 方案3: 使用其他兼容 OpenAI 的 API
# OPENAI_API_KEY=your_key
# OPENAI_BASE_URL=https://your-api-endpoint.com/v1
# OPENAI_MODEL=your-model-name
